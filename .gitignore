.DS_Store
.build/
*.xcodeproj/xcuserdata/
Models/*
# …but the hand-authored keywords file is a small tracked text artifact.
!Models/keywords.txt
Sources/CSherpaOnnx/sherpa-onnx.xcframework/
Tests/HeyClaudeKitTests/Fixtures/*.wav
*.onnx

# Fonts: General Sans (ITF Free Font License) is NOT redistributable — keep the
# .otf files local, never commit them. The app falls back to the system font.
*.otf

# Secrets / signing material — must never be committed.
*.p12
*.mobileprovision
.env
.env.*

# Maintainer-only release tooling (personal signing/notarization identity).
scripts/release.sh
scripts/entitlements.plist

# Landing pages live in their own repos — ignored here.
site/
web/
.playwright-mcp/

# Built app bundle (assembled by scripts/bundle-app.sh)
HeyClaude.app/
# Release artifacts (assembled by scripts/release.sh) — large, regenerated builds.
HeyClaude.dmg
HeyClaude-notarize.zip
.superpowers/
